{
  "name": "webtoon-media-browser",
  "version": "0.2.6",
  "description": "A Webtoon-style local image and video browser with 3D stereo support",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "start": "electron .",
    "package": "npm run build && npx @electron/packager . \"Webtoon Media Browser\" --platform=win32 --arch=x64 --out=versions --overwrite --asar",
    "package:win": "npm run package"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.18.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^42.5.0",
    "electron-builder": "^24.9.1",
    "electron-packager": "^17.1.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  },
  "build": {
    "appId": "com.webtoon.mediabrowser",
    "productName": "Webtoon Media Browser",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "!versions/**/*",
      "!node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
